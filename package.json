{
  "name": "mini-plate-editor",
  "version": "0.1.0",
  "description": "A Plate.js WYSIWYG markdown editor with directive support",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@udecode/plate": "^48",
    "@udecode/plate-basic-marks": "^48",
    "@udecode/plate-block-quote": "^48",
    "@udecode/plate-heading": "^48",
    "@udecode/plate-horizontal-rule": "^48",
    "@udecode/plate-list": "^48",
    "@udecode/plate-media": "^48",
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19"
  },
  "devDependencies": {
    "@types/react": "^18 || ^19",
    "@types/react-dom": "^18 || ^19",
    "@udecode/plate": "^48",
    "@udecode/plate-basic-marks": "^48",
    "@udecode/plate-block-quote": "^48",
    "@udecode/plate-heading": "^48",
    "@udecode/plate-horizontal-rule": "^48",
    "@udecode/plate-list": "^48",
    "@udecode/plate-media": "^48",
    "react": "^19",
    "react-dom": "^19",
    "tsup": "^8.5.1",
    "typescript": "^5"
  },
  "keywords": [
    "plate",
    "editor",
    "wysiwyg",
    "markdown",
    "react"
  ],
  "license": "MIT"
}
